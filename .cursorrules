## API — Mocked Today

```typescript
// lib/api.ts
import type { Message } from '@/types'

// MOCKED — replace with real fetch() calls tomorrow
// Real endpoint will be: POST http://localhost:8000/api/messages/{sessionId}

const MOCK_SESSION_ID = 'session-001'

const mockHistory: Message[] = []

export async function sendMessage(content: string): Promise<Message> {
  await new Promise(r => setTimeout(r, 1200)) // fake Gemini delay

  const aiReplies = [
    'That\'s a great question! Let me think about that...',
    'Interesting! Here\'s what I know about that topic.',
    'I understand what you\'re asking. Here\'s my response.',
    'Good point! Based on my knowledge, I would say...',
  ]

  const reply = aiReplies[Math.floor(Math.random() * aiReplies.length)]

  return {
    id: Date.now().toString(),
    role: 'assistant',
    content: reply,
    createdAt: new Date().toISOString()
  }
}

export async function getMessages(): Promise<Message[]> {
  await new Promise(r => setTimeout(r, 300))
  return mockHistory  // empty on first load — fine for today
}

export { MOCK_SESSION_ID }
```

